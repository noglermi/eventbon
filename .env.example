NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Production public app URL.
# Developers should override this locally in .env.local, for example:
# NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=https://eventbons.com

# QZ Tray trusted printing.
# QZ_TRAY_DIGITAL_CERTIFICATE is the public EventBon certificate shown by QZ Tray.
# QZ_TRAY_PRIVATE_KEY must stay server-side only and must never be exposed with NEXT_PUBLIC_.
# Multiline PEM values can be stored with escaped newlines in hosted environments.
QZ_TRAY_DIGITAL_CERTIFICATE=
QZ_TRAY_PRIVATE_KEY=
